# Copy to .env for local dev, or set these as Variables in Railway.
# Railway provides DATABASE_URL automatically when you add a Postgres plugin.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# A long random string that signs login sessions. Change this!
SECRET_KEY=change-me-to-a-long-random-string

# The PIN for the first Admin account, created automatically on first run.
# Log in as "Admin" with this PIN, then change it under Staff.
ADMIN_INITIAL_PIN=123456
